# RealDoor / ProofSetu environment variables
# Commit ONLY this file with EMPTY placeholder values.
# Never commit a real .env, and never paste secrets into code, PRs, issues,
# screenshots, demo recordings, or AI-agent prompts.

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=        # Backend develop deployment URL
NEXT_PUBLIC_USE_MOCKS=true       # true until live integration; keep for demo fallback

# --- Backend: session store ---
SESSION_BACKEND=memory           # upstash | memory
UPSTASH_REDIS_REST_URL=          # secret; deployment environment only
UPSTASH_REDIS_REST_TOKEN=        # secret; deployment environment only
SESSION_TTL_SECONDS=3600         # short demo TTL, e.g. 3600-7200

# --- Backend: extraction (Member 2) ---
OCR_PROVIDER=fixture             # textract | tesseract | fixture
VISION_PROVIDER=fixture          # openai | gemini | fixture
AWS_ACCESS_KEY_ID=               # secret; only if AWS Textract is used
AWS_SECRET_ACCESS_KEY=           # secret; only if AWS Textract is used
AWS_REGION=
OPENAI_API_KEY=                  # secret; sponsor key/credit only
GEMINI_API_KEY=                  # secret; fallback only

# --- Backend: rules (Member 3) ---
RULE_INDEX=keyword               # chroma | faiss | keyword

# --- Backend: shared ---
MAX_UPLOAD_MB=10                 # small cap, e.g. 8-10 MB
CORS_ORIGINS=                    # exact frontend preview/production origins, comma-separated
