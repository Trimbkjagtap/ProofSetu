# Copy to .env.local for local development.
#
# API mode: "mock" (default, hackathon demo) returns bundled sample extraction
# per document type. "live" sends the real uploaded/scanned file to the backend
# extraction endpoint via multipart/form-data.
NEXT_PUBLIC_API_MODE=mock

# Backend base URL used in live mode.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Do not put API keys here. The frontend never holds secrets.
